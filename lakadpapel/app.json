{
  "expo": {
    "name": "LakadPapel",
    "slug": "lakadpapel",
    "scheme": "lakadpapel",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo-splash.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/logo-splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF8F5"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.group4.lakadpapel",
      "splash": {
        "image": "./assets/logo-splash.png",
        "resizeMode": "contain",
        "backgroundColor": "#FFF8F5"
      }
    },
    "android": {
      "package": "com.group4.lakadpapel",
      "adaptiveIcon": {
        "backgroundColor": "#FFF8F5",
        "foregroundImage": "./assets/logo-splash.png"
      },
      "splash": {
        "image": "./assets/logo-splash.png",
        "resizeMode": "contain",
        "backgroundColor": "#FFF8F5"
      }
    },
    "web": {
      "favicon": "./assets/logo-header.png"
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
